rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 공통 인증 체크
    function isSignedIn() {
      return request.auth != null;
    }

    // 관리자 권한은 custom claims(admin=true)로만 판별
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // 본인 문서 접근 체크
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // 닉네임 규칙(2~12자) 확인
    function isValidNickname(nickname) {
      return nickname is string
        && nickname.size() >= 2
        && nickname.size() <= 12;
    }

    // ----------------------------
    // users
    // ----------------------------
    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && isValidNickname(request.resource.data.nickname);

      allow update: if (
          isOwner(uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && isValidNickname(request.resource.data.nickname)
        ) || isAdmin();

      allow delete: if isAdmin();
    }

    // ----------------------------
    // projects
    // ----------------------------
    match /projects/{projectId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.status is string;

      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
    }

    // ----------------------------
    // project_logs
    // ----------------------------
    match /project_logs/{logId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.projectId is string
        && request.resource.data.summary is string
        && request.resource.data.summary.size() > 0
        && request.resource.data.summary.size() <= 800;

      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.authorUid == request.auth.uid);
    }

    // ----------------------------
    // project_threads
    // ----------------------------
    match /project_threads/{threadId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.projectId is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120;

      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    // 스레드 메시지는 하위 컬렉션으로 분리해 메시지 권한을 독립 관리
    match /project_threads/{threadId}/messages/{messageId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.projectId is string
        && request.resource.data.authorNickname is string
        && request.resource.data.authorNickname.size() > 0
        && request.resource.data.authorNickname.size() <= 24
        && request.resource.data.messageType in ['GENERAL', 'QUESTION', 'FEEDBACK', 'REFERENCE']
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.createdAt == request.time;

      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.authorUid == request.auth.uid);
    }

    // ----------------------------
    // focus_sessions
    // ----------------------------
    match /focus_sessions/{sessionId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.durationSec is int
        && request.resource.data.durationSec >= 0;

      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userUid == request.auth.uid);
    }

    // ----------------------------
    // donations (서버 검증 기록 전용)
    // ----------------------------
    match /donations/{donationId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ----------------------------
    // legacy messages (점진적 마이그레이션 용도)
    // ----------------------------
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 300;
      allow update, delete: if isAdmin();
    }
  }
}
