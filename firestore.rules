rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidNickname(nickname) {
      return nickname is string
        && nickname.size() >= 2
        && nickname.size() <= 12;
    }

    function isCreatableNickname(nickname) {
      return nickname is string
        && nickname.size() <= 12;
    }

    function projectDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId));
    }

    function projectExists(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId));
    }

    function projectRole(projectId) {
      return projectDoc(projectId).data.ownerUid == request.auth.uid
        ? "owner"
        : (
          projectDoc(projectId).data.memberRoles is map
          && projectDoc(projectId).data.memberRoles[request.auth.uid] is string
            ? projectDoc(projectId).data.memberRoles[request.auth.uid]
            : (
              projectDoc(projectId).data.members is list
              && request.auth.uid in projectDoc(projectId).data.members
                ? "editor"
                : ""
            )
        );
    }

    function canAccessProject(projectId) {
      return isSignedIn()
        && projectExists(projectId)
        && (
          isAdmin()
          || projectRole(projectId) == "owner"
          || projectRole(projectId) == "editor"
          || projectRole(projectId) == "viewer"
        );
    }

    function canEditProjectContent(projectId) {
      return isSignedIn()
        && projectExists(projectId)
        && (
          isAdmin()
          || projectRole(projectId) == "owner"
          || projectRole(projectId) == "editor"
        );
    }

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && isCreatableNickname(request.resource.data.nickname);

      allow update: if (
          isOwner(uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && isValidNickname(request.resource.data.nickname)
        ) || isAdmin();

      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if canAccessProject(projectId);

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.status is string
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members
        && request.resource.data.memberRoles is map
        && request.resource.data.memberRoles[request.auth.uid] == "owner";

      // 프로젝트 메타/멤버 관리는 owner 또는 admin만 허용한다.
      allow update: if isAdmin() || (
          isSignedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.members is list
          && request.auth.uid in request.resource.data.members
          && (
            (request.resource.data.memberRoles is map
              && request.resource.data.memberRoles[resource.data.ownerUid] == "owner")
            || (
              !(resource.data.memberRoles is map)
              && !(request.resource.data.memberRoles is map)
            )
          )
        );

      allow delete: if isAdmin() || (
          isSignedIn() && resource.data.ownerUid == request.auth.uid
        );
    }

    match /project_logs/{logId} {
      allow read: if isSignedIn() && canAccessProject(resource.data.projectId);

      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.projectId is string
        && canEditProjectContent(request.resource.data.projectId)
        && request.resource.data.summary is string
        && request.resource.data.summary.size() > 0
        && request.resource.data.summary.size() <= 800
        && request.resource.data.createdAt == request.time;

      allow update: if isAdmin() || (
          isSignedIn()
          && (
            resource.data.authorUid == request.auth.uid
            || canEditProjectContent(resource.data.projectId)
          )
          && request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.projectId == resource.data.projectId
          && canAccessProject(resource.data.projectId)
        );

      allow delete: if isAdmin() || (
          isSignedIn()
          && (
            resource.data.authorUid == request.auth.uid
            || canEditProjectContent(resource.data.projectId)
          )
          && canAccessProject(resource.data.projectId)
        );
    }

    match /project_threads/{threadId} {
      allow read: if isSignedIn() && canAccessProject(resource.data.projectId);

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.projectId is string
        && canEditProjectContent(request.resource.data.projectId)
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120;

      allow update, delete: if isAdmin() || (
          isSignedIn() && resource.data.createdBy == request.auth.uid
        );
    }

    match /project_threads/{threadId}/messages/{messageId} {
      allow read: if isSignedIn()
        && canAccessProject(get(/databases/$(database)/documents/project_threads/$(threadId)).data.projectId);

      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.projectId is string
        && request.resource.data.projectId == get(/databases/$(database)/documents/project_threads/$(threadId)).data.projectId
        && canEditProjectContent(request.resource.data.projectId)
        && request.resource.data.authorNickname is string
        && request.resource.data.authorNickname.size() > 0
        && request.resource.data.authorNickname.size() <= 24
        && request.resource.data.messageType in ['GENERAL', 'QUESTION', 'FEEDBACK', 'REFERENCE']
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.messageKeywords is list
        && request.resource.data.messageKeywords.size() <= 20
        && request.resource.data.createdAt == request.time;

      allow update, delete: if isAdmin() || (
          isSignedIn()
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.projectId == resource.data.projectId
          && request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.authorNickname == resource.data.authorNickname
          && request.resource.data.messageType == resource.data.messageType
          && request.resource.data.createdAt == resource.data.createdAt
        );
    }

    match /focus_sessions/{sessionId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.startedAt is timestamp
        && request.resource.data.endedAt is timestamp
        && request.resource.data.dateKey is string
        && request.resource.data.dateKey.size() == 10
        && request.resource.data.durationSec is int
        && request.resource.data.durationSec >= 30
        && request.resource.data.durationSec <= 86400;

      allow update, delete: if isAdmin() || (
          isSignedIn() && resource.data.userUid == request.auth.uid
        );
    }

    match /donations/{donationId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 300;
      allow update, delete: if isAdmin();
    }
  }
}
